{
  "name": "ai-workflow",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "author": "",
  "scripts": {
    "dev": "pnpm run -F @ai-workflow/web dev",
    "build": "turbo run build",
    "lint": "oxlint .",
    "lint:staged": "oxlint . --fix",
    "format:staged": "prettier --write --config ./configs/prettier/.prettierrc.json --ignore-path ./configs/prettier/.prettierignore",
    "format:check": "prettier . --check --config ./configs/prettier/.prettierrc.json --ignore-path ./configs/prettier/.prettierignore",
    "check": "pnpm format:check && pnpm lint",
    "husky:init": "npx husky init",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "pnpm lint:staged",
      "pnpm format:staged"
    ],
    "*.{json,css,scss,md,mdx}": "pnpm format:staged"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-vinyl"
    }
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@oxlint/binding-darwin-arm64": "1.62.0",
    "@rolldown/binding-darwin-arm64": "1.0.0-rc.17",
    "@tailwindcss/vite": "^4.2.4",
    "commitizen": "^4.3.1",
    "commitlint": "^20.5.2",
    "cz-vinyl": "^1.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.62.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tailwindcss": "^4.2.4",
    "turbo": "^2.9.6"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  }
}
